<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Main rounded rectangle bubble body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bubble_user_purple" />
            <corners android:radius="15dp" />
        </shape>
    </item>

    <!-- Tail pointer at bottom-right - extends outward from bubble -->
    <item
        android:width="16dp"
        android:height="16dp"
        android:gravity="bottom|end"
        android:bottom="-8dp"
        android:right="20dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="@color/bubble_user_purple" />
            </shape>
        </rotate>
    </item>

</layer-list>

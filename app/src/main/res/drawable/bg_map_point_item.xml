<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#6B5B9A"
                android:centerColor="#6B600A"
                android:endColor="#6B5B9A"
                android:type="linear" />
            <corners android:radius="32dp" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#3D2A6A" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>
